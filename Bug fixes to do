✅ 2️⃣ Fix: Broken Save / Load Logic (.ztmy)

Replace your entire loadGame() function with this improved version:

function loadGame(event) {
  const file = event.target.files[0];
  if (!file) return;

  const reader = new FileReader();

  reader.onload = function(e) {
    try {
      const data = JSON.parse(e.target.result);

      // Core values
      score = data.score ?? 0;
      autoClickers = data.autoClickers ?? 0;
      multiplier = data.multiplier ?? 1;
      runningMatitsOwned = data.runningMatitsOwned ?? 0;

      // Unlocks
      musicUnlocked = data.musicUnlocked ?? false;
      casinoUnlocked = data.casinoUnlocked ?? false;
      cosmeticsUnlocked = data.cosmeticsUnlocked ?? false;

      // Prices
      autoclickerPrice = data.autoclickerPrice ?? 30;
      runningMatitPrice = data.runningMatitPrice ?? 300;

      // Skin
      currentSkin = data.currentSkin ?? "button1.jpg";
      setSkin(currentSkin);

      // Tracks
      if (data.ownedTracks) {
        tracks.forEach(t => {
          t.owned = data.ownedTracks.includes(t.id);
        });
      }

      // Cosmetics
      if (data.ownedCosmetics) {
        cosmetics.forEach(c => {
          c.owned = data.ownedCosmetics.includes(c.id);
        });
      }

      // Achievements
      if (data.unlockedAchievements) {
        achievements.forEach(ach => {
          ach.unlocked = data.unlockedAchievements.includes(ach.id);
        });
      }

      // 🔥 Recreate running animations
      document.querySelectorAll(".running-matit-video").forEach(v => v.remove());
      for (let i = 0; i < runningMatitsOwned; i++) {
        spawnRunningVideo();
      }

      updateDisplay();
      updateAchievementsUI();
      initCosmeticShop();
      alert("Save Loaded Successfully!");

    } catch (err) {
      alert("⚠️ Corrupted or invalid save file.");
      console.error(err);
    }
  };

  reader.readAsText(file);
}
